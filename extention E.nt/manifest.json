{
  "name": "E.nt",
  "description": "Customisation extention for ENT",
  "version": "1.0",
  "manifest_version": 3,

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "permissions": ["storage"],

  "content_scripts": [
    {
      "css": ["scripts/style.css"],
      "js": ["scripts/content.js"],
      "run_at": "document_start",
      "matches": [
        "https://aubrac-isere.ent.auvergnerhonealpes.fr/*",
        "https://cas.ent.auvergnerhonealpes.fr/*",
        "https://educonnect.education.gouv.fr/idp/profile/SAML2/POST/*",
        "https://www.ent.auvergnerhonealpes.fr/*"
      ]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "E.NT@shaogufi.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
